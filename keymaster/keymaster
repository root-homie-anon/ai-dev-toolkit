def cmd_remove(args):
    """Remove a key from the vault."""
    vault = load_vault()
    config = load_config()
    key_name = args.key.upper()
    target_project = getattr(args, "project", None)

    found = False

    if key_name in vault["shared"]:
        if target_project:
            # Remove from one project only
            projs = vault["shared"][key_name].get("projects", [])
            if target_project in projs:
                projs.remove(target_project)
                if not projs:
                    del vault["shared"][key_name]
                    print(f"  Removed shared key '{key_name}' (no projects left).")
                else:
                    vault["shared"][key_name]["projects"] = projs
                    print(f"  Removed '{target_project}' from shared key '{key_name}'. Remaining: {', '.join(projs)}")
                found = True
        else:
            projs = vault["shared"][key_name].get("projects", [])
            confirm = input(f"Remove shared key '{key_name}' from all {len(projs)} projects? [y/N] ").strip().lower()
            if confirm == "y":
                del vault["shared"][key_name]
                found = True
                print(f"  Removed shared key '{key_name}'.")

    if not found:
        search_proj = target_project or None
        for proj in list(vault.get("project", {}).keys()):
            if search_proj and proj != search_proj:
                continue
            if key_name in vault["project"].get(proj, {}):
                del vault["project"][proj][key_name]
                if not vault["project"][proj]:
                    del vault["project"][proj]
                print(f"  Removed '{key_name}' from {proj}.")
                found = True
                break

    if found:
        save_vault(vault)
        log_history(key_name, "removed", [target_project or "all"])
    else:
        print(f"{RED}Key '{key_name}' not found.{RESET}")


def cmd_history(args):
    """Show rotation/change history."""
    log_file = HISTORY_DIR / "audit.jsonl"
    if not log_file.exists():
        print("No history yet.")
        return

    key_filter = getattr(args, "key", None)
    if key_filter:
        key_filter = key_filter.upper()

    print(f"\n{BOLD}Key History{RESET}")
    print("-" * 80)

    with open(log_file) as f:
        entries = [json.loads(line) for line in f if line.strip()]

    if key_filter:
        entries = [e for e in entries if e.get("key", "").upper() == key_filter]

    for entry in entries[-30:]:  # Last 30 entries
        ts = entry.get("timestamp", "")[:19]
        key = entry.get("key", "")
        action = entry.get("action", "")
        projs = ", ".join(entry.get("projects", []))

        color = GREEN if action == "added" else (YELLOW if action == "rotated" else RED)
        print(f"  {DIM}{ts}{RESET}  {color}{action:<10}{RESET}  {BOLD}{key:<30}{RESET}  {projs}")

    print()


