def cmd_require(args):
    """Declare keys a project needs via keys.json manifest."""
    vault = load_vault()
    config = load_config()
    project_name = args.project
    key_names = [k.upper() for k in args.keys]

    if project_name not in config.get("projects", {}):
        print(f"{RED}Unknown project '{project_name}'. Run 'keymaster projects' to see available.{RESET}")
        return

    project_path = config["projects"][project_name]["path"]
    manifest_path = Path(project_path) / "keys.json"

    # Load existing manifest or start fresh
    manifest = {}
    if manifest_path.exists():
        with open(manifest_path) as f:
            manifest = json.load(f)

    if "keys" not in manifest:
        manifest["keys"] = {}

    shared = vault.get("shared", {})
    project_keys = vault.get("project", {})

    added = []
    needs_value = []

    for key_name in key_names:
        entry = {"required": True}

        # Check if it exists in vault
        if key_name in shared:
            entry["source"] = key_name
            # Auto-assign project to shared key if not already
            if project_name not in shared[key_name].get("projects", []):
                shared[key_name]["projects"].append(project_name)
                shared[key_name]["projects"].sort()
                print(f"  {GREEN}Assigned{RESET} shared key '{key_name}' to {project_name}")
        elif key_name in project_keys.get(project_name, {}):
            entry["source"] = key_name
        else:
            # Key not in vault — check if it's an alias for a shared key
            found_source = None
            for vk, vinfo in shared.items():
                aliases = vinfo.get("aliases", {})
                if key_name in aliases.values():
                    found_source = vk
                    break

            if found_source:
                entry["source"] = found_source
                if project_name not in shared[found_source]["projects"]:
                    shared[found_source]["projects"].append(project_name)
                    shared[found_source]["projects"].sort()
                print(f"  {GREEN}Mapped{RESET} '{key_name}' -> vault key '{found_source}'")
            else:
                needs_value.append(key_name)
                entry["source"] = None

        manifest["keys"][key_name] = entry
        added.append(key_name)

    # Save manifest
    with open(manifest_path, "w") as f:
        json.dump(manifest, f, indent=2)
    print(f"\n  {GREEN}Updated{RESET} {project_name}/keys.json ({len(added)} keys)")

    # Save vault (shared key project assignments may have changed)
    save_vault(vault)

    if needs_value:
        print(f"\n  {YELLOW}Keys not yet in vault (need to be added):{RESET}")
        for k in needs_value:
            print(f"    {YELLOW}{k}{RESET} — run 'keymaster add {k}' to add it")

    # Sync
    _do_sync(vault, config, only_projects=[project_name])
    print()


def cmd_check(args):
    """Check if a project has all its required keys."""
    vault = load_vault()
    config = load_config()

    check_projects = [args.project] if args.project else list(config.get("projects", {}).keys())
    shared = vault.get("shared", {})
    project_keys = vault.get("project", {})

    print(f"\n{BOLD}Key Requirements Check{RESET}")
    print("=" * 50)

    for project_name in sorted(check_projects):
        if project_name not in config.get("projects", {}):
            print(f"\n  {RED}Unknown project: {project_name}{RESET}")
            continue

        project_path = config["projects"][project_name]["path"]
        manifest = _load_manifest(project_path)

        if not manifest.get("keys"):
            continue

        missing = []
        satisfied = []
        empty = []

        for req_key, req_info in manifest["keys"].items():
            source = req_info.get("source")
            required = req_info.get("required", True)

            if not source:
                missing.append(req_key)
                continue

            # Check if source key exists and has a value
            val = None
            if source in shared and project_name in shared[source].get("projects", []):
                val = shared[source].get("value", "")
            elif source in project_keys.get(project_name, {}):
                val = project_keys[project_name][source].get("value", "")

            if val is None:
                missing.append(req_key)
            elif val == "":
                empty.append(req_key)
            else:
                satisfied.append(req_key)

        # Report
        total = len(manifest["keys"])
        ok = len(satisfied)
        status = f"{GREEN}OK{RESET}" if ok == total else f"{RED}{total - ok} missing{RESET}"

        print(f"\n  {BOLD}{project_name}{RESET} — {ok}/{total} keys satisfied [{status}]")

        if missing:
            for k in missing:
                print(f"    {RED}MISSING: {k}{RESET} — run 'keymaster add {k}' or 'keymaster require {project_name} {k}'")
        if empty:
            for k in empty:
                print(f"    {YELLOW}EMPTY:   {k}{RESET} — key exists but has no value")

    print()


def cmd_alias(args):
    """Set an alias so a shared vault key writes with a different name in a project's .env."""
    vault = load_vault()
    config = load_config()
    vault_key = args.vault_key.upper()
    alias_name = args.alias.upper()
    project_name = args.project

    if vault_key not in vault.get("shared", {}):
        print(f"{RED}'{vault_key}' is not a shared key in the vault.{RESET}")
        return

    if project_name not in config.get("projects", {}):
        print(f"{RED}Unknown project '{project_name}'.{RESET}")
        return

    if "aliases" not in vault["shared"][vault_key]:
        vault["shared"][vault_key]["aliases"] = {}

    vault["shared"][vault_key]["aliases"][project_name] = alias_name
    save_vault(vault)

    print(f"  {GREEN}Alias set:{RESET} {vault_key} -> {alias_name} in {project_name}")

    # Sync that project
    _do_sync(vault, config, only_projects=[project_name])
    print()


# ── CLI ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="keymaster",
        description="Centralized API key manager for local development.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command")

    # init
    sub.add_parser("init", help="Import existing .env files into vault")

    # status
    sub.add_parser("status", help="Dashboard overview")

    # list
    p_list = sub.add_parser("list", help="List keys")
    p_list.add_argument("--project", "-p", help="Filter by project")
    p_list.add_argument("--shared", "-s", action="store_true", help="Show shared keys only")
    p_list.add_argument("--category", "-c", help="Filter by category")

    # add
    p_add = sub.add_parser("add", help="Add or update a key")
    p_add.add_argument("key", help="Key name (e.g. ANTHROPIC_API_KEY)")

    # get
    p_get = sub.add_parser("get", help="Get a key value")
    p_get.add_argument("key", help="Key name")
    p_get.add_argument("--unmask", "-u", action="store_true", help="Show full value")

    # rotate
    p_rotate = sub.add_parser("rotate", help="Rotate a key")
    p_rotate.add_argument("key", help="Key name to rotate")

    # sync
    p_sync = sub.add_parser("sync", help="Regenerate .env files from vault")
    p_sync.add_argument("project", nargs="?", help="Sync specific project only")

    # audit
    sub.add_parser("audit", help="Security audit")

    # projects
    sub.add_parser("projects", help="List registered projects")

    # remove
    p_rm = sub.add_parser("remove", help="Remove a key")
    p_rm.add_argument("key", help="Key name")
    p_rm.add_argument("--project", "-p", help="Remove from specific project only")

    # history
    p_hist = sub.add_parser("history", help="Show change history")
    p_hist.add_argument("key", nargs="?", help="Filter by key name")

    # fix-gitignore
    sub.add_parser("fix-gitignore", help="Add .gitignore protection to all projects")

    # require
    p_req = sub.add_parser("require", help="Declare keys a project needs (creates keys.json)")
    p_req.add_argument("project", help="Project name")
    p_req.add_argument("keys", nargs="+", help="Key names the project needs")

    # check
    p_check = sub.add_parser("check", help="Check if a project has all required keys")
    p_check.add_argument("project", nargs="?", help="Project to check (all if omitted)")

    # alias
    p_alias = sub.add_parser("alias", help="Set an alias for a shared key in a project")
    p_alias.add_argument("vault_key", help="Vault key name (e.g. BFL_API_KEY)")
    p_alias.add_argument("alias", help="Alias name for .env (e.g. FLUX_API_KEY)")
    p_alias.add_argument("project", help="Project name")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return

    commands = {
        "init": cmd_init,
        "status": cmd_status,
        "list": cmd_list,
        "add": cmd_add,
        "get": cmd_get,
        "rotate": cmd_rotate,
        "sync": cmd_sync,
        "audit": cmd_audit,
        "projects": cmd_projects,
        "remove": cmd_remove,
        "history": cmd_history,
        "fix-gitignore": cmd_fix_gitignore,
        "require": cmd_require,
        "check": cmd_check,
        "alias": cmd_alias,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
