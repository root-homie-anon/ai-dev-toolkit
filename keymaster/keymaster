def cmd_audit(args):
    """Audit for security issues."""
    vault = load_vault()
    config = load_config()
    issues = []
    warnings = []

    print(f"\n{BOLD}KeyMaster Security Audit{RESET}")
    print("=" * 50)

    # 1. Check .gitignore in all projects
    for name, info in config.get("projects", {}).items():
        gitignore = Path(info["path"]) / ".gitignore"
        if not gitignore.exists():
            issues.append(f"{RED}MISSING .gitignore: {name}{RESET} — .env could be committed")
        else:
            content = gitignore.read_text()
            if ".env" not in content:
                issues.append(f"{RED}NO .env IN .gitignore: {name}{RESET} — .env not protected")

    # 2. Check vault file permissions
    if VAULT_PATH.exists():
        mode = oct(VAULT_PATH.stat().st_mode)[-3:]
        if mode != "600":
            issues.append(f"{RED}VAULT PERMISSIONS: {mode} (should be 600){RESET}")

    # 3. Check for empty/weak values
    for k, info in vault.get("shared", {}).items():
        val = info.get("value", "")
        if not val:
            issues.append(f"{RED}EMPTY VALUE: {k} (shared){RESET}")
        elif is_secret(k) and len(val) < 10:
            warnings.append(f"{YELLOW}WEAK VALUE: {k} — only {len(val)} chars{RESET}")

    for proj, keys in vault.get("project", {}).items():
        for k, info in keys.items():
            val = info.get("value", "")
            if not val:
                issues.append(f"{RED}EMPTY VALUE: {k} ({proj}){RESET}")
            elif is_secret(k) and len(val) < 10:
                warnings.append(f"{YELLOW}WEAK VALUE: {k} ({proj}) — only {len(val)} chars{RESET}")

    # 4. Check for .env files not managed by vault
    for name, info in config.get("projects", {}).items():
        env_path = Path(info["path"]) / ".env"
        if env_path.exists():
            disk_keys = set(parse_env_file(env_path).keys())
            vault_keys = set()
            for k, kinfo in vault.get("shared", {}).items():
                if name in kinfo.get("projects", []):
                    vault_keys.add(k)
            if name in vault.get("project", {}):
                vault_keys.update(vault["project"][name].keys())

            unmanaged = disk_keys - vault_keys
            if unmanaged:
                warnings.append(f"{YELLOW}UNMANAGED KEYS in {name}/.env: {', '.join(sorted(unmanaged))}{RESET}")

    # 5. Check for duplicate values across different key names (possible copy-paste error)
    all_secrets = {}
    for k, info in vault.get("shared", {}).items():
        if is_secret(k) and info.get("value"):
            v = info["value"]
            all_secrets.setdefault(v, []).append(k)
    for proj, keys in vault.get("project", {}).items():
        for k, info in keys.items():
            if is_secret(k) and info.get("value"):
                v = info["value"]
                all_secrets.setdefault(v, []).append(f"{k} ({proj})")

    for val, key_names in all_secrets.items():
        if len(key_names) > 1:
            # Skip if they're clearly the same key (e.g., YOUTUBE_API_KEY across projects)
            base_names = [n.split(" (")[0] for n in key_names]
            if len(set(base_names)) > 1:
                warnings.append(f"{YELLOW}DUPLICATE VALUE across different keys: {', '.join(key_names)}{RESET}")

    # Report
    if issues:
        print(f"\n  {RED}{BOLD}Issues ({len(issues)}):{RESET}")
        for i in issues:
            print(f"    {i}")

    if warnings:
        print(f"\n  {YELLOW}{BOLD}Warnings ({len(warnings)}):{RESET}")
        for w in warnings:
            print(f"    {w}")

    if not issues and not warnings:
        print(f"\n  {GREEN}No issues found.{RESET}")
    elif issues:
        print(f"\n  {BOLD}Fix issues above, then run 'keymaster audit' again.{RESET}")

    print()


